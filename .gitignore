# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# Python packaging/build outputs
build/
dist/
*.egg-info/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment variables and local secrets
.env
.env.*
!.env.example
.streamlit/secrets.toml
*.pem
*.key

# Logs and temporary files
*.log
logs/
tmp/
temp/

# RenovateAI runtime inputs and generated outputs
data/inputs/*
data/outputs/*
!data/inputs/.gitkeep
!data/outputs/.gitkeep

# ML/model artifacts and local caches
.cache/
models/
checkpoints/
*.ckpt
*.safetensors
*.pt
*.pth
*.onnx
*.bin
*.gguf

# OS and editor files
.DS_Store
Thumbs.db
Desktop.ini
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
